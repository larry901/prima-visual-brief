# Vercel Postgres (required) — copy from Vercel dashboard → Storage → your DB → .env.local tab
POSTGRES_URL=postgres://user:password@host/db?sslmode=require
POSTGRES_URL_NON_POOLING=postgres://user:password@host/db?sslmode=require

# Spotify (required) — Client Credentials flow + a public playlist for reference songs
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_PLAYLIST_ID=6tk5vOlKor3dioJJPXAhBj

# Email (required) — Resend API key, sends from clients@primavisual.io
EMAIL_API_KEY=your_resend_api_key

# Dashboard auth
DASHBOARD_PASSWORD=your_secure_password
